<!DOCTYPE html>
<html>
<head>
  <title>AI Signal</title>
</head>
<body>

<h2 id="signal">Signal: Loading...</h2>

<script>
function generateSignal() {
  const signals = ["BUY 🚀", "SELL 🔻", "HOLD ⏸️"];
  const random = signals[Math.floor(Math.random() * signals.length)];
  document.getElementById("signal").innerText = "Signal: " + random;
}

setInterval(generateSignal, 4000);
generateSignal();
</script>

</body>
</html>
