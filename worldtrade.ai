<!DOCTYPE html>
<html>
<head>
  <title>WorldTrade AI</title>
  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0D0D0D;
      color: white;
      text-align: center;
    }

    .hero {
      padding: 80px 20px;
    }

    h1 {
      font-size: 40px;
      color: #00FF9C;
    }

    .btn {
      background: #00D1FF;
      padding: 15px 25px;
      border-radius: 10px;
      color: black;
      text-decoration: none;
      font-weight: bold;
    }

    .section {
      padding: 50px 20px;
    }

    .card {
      background: #1A1A1A;
      padding: 20px;
      margin: 10px;
      border-radius: 15px;
      display: inline-block;
      width: 250px;
    }
  </style>
</head>

<body>

<div class="hero">
  <h1>WorldTrade AI</h1>
  <p>Trade Crypto Smarter with AI</p>
  <a href="#" class="btn">Download App</a>
</div>

<div class="section">
  <h2>Features</h2>

  <div class="card">💰 Crypto Wallet</div>
  <div class="card">📊 Live Market Tracking</div>
  <div class="card">🖼️ NFT Marketplace</div>
  <div class="card">💳 GCash Integration</div>
</div>

<div class="section">
  <h2>How It Works</h2>
  <p>1. Create account</p>
  <p>2. Deposit via GCash</p>
  <p>3. Trade crypto instantly</p>
</div>

<div class="section">
  <h2>Join Early Access</h2>
  <p>Be one of the first users 🚀</p>
  <a href="#" class="btn">Get Started</a>
</div>

<script type="module" src="/speed-insights.js"></script>
</body>
</html>
