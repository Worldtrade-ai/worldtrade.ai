if(user){
document.getElementById("userEmail").innerText = "Logged in as: " + user.email
}else{
window.location.href="index.html"
}
});


// ---------- CONNECT WALLET ----------
async function connectWallet(){

if(window.ethereum){

try{

const accounts = await window.ethereum.request({
method:"eth_requestAccounts"
})

document.getElementById("wallet").innerText = accounts[0]

}catch(err){

alert("Wallet connection failed")

}

}else{

alert("Please install MetaMask wallet")

}

}

window.connectWallet = connectWallet



// ---------- LIVE BTC PRICE ----------
async function getPrices(){

try{

const res = await fetch(
"https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT"
)

const data = await res.json()

document.getElementById("btc").innerText = parseFloat(data.price).toFixed(2)

document.getElementById("usdt").innerText = "1.00"

}catch(err){

console.log("Price error")

}

}

setInterval(getPrices,5000)
getPrices()


// ---------- AI SIGNAL ----------
function aiSignal(){

const signals=[
"BUY BTC",
"SELL BTC",
"HOLD BTC",
"STRONG BUY",
"WAIT FOR ENTRY"
]

const random = signals[Math.floor(Math.random()*signals.length)]

document.getElementById("signal").innerText = random

}

setInterval(aiSignal,7000)
aiSignal()



// ---------- NFT DEMO ----------
async function loadNFTs(){

const container = document.getElementById("nfts")

container.innerHTML="Loading NFTs..."

try{

const res = await fetch(
"https://api.opensea.io/api/v2/collections?limit=3"
)

const data = await res.json()

let html=""

data.collections.forEach(nft=>{

html+=`
<div style="border:1px solid #444;padding:10px;margin:10px;">
<h3>${nft.name}</h3>
<p>${nft.description || "NFT Collection"}</p>
</div>
`

})

container.innerHTML=html

}catch(err){

container.innerHTML="NFT marketplace unavailable"

}

}

loadNFTs()